{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "school.schema.json",
  "title": "FN5GL High School Data",
  "type": "object",
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": "string" },
    "school_website": { "type": "string", "format": "uri" },
    "city": { "type": "string" },
    "state": { "type": "string", "minLength": 2, "maxLength": 2 },
    "region": { "type": "string", "enum": ["East", "West", "Central", "South"] },
    "votes_phase_1": { "type": "integer", "minimum": 0 },
    "votes_phase_2": { "type": "integer", "minimum": 0 },
    "rank": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "home_game": {
      "type": "object",
      "properties": {
        "datetime": { "type": "string", "format": "date-time" },
        "stadium_name": { "type": "string" },
        "stadium_address": { "type": "string" }
      },
      "required": ["datetime", "stadium_name", "stadium_address"]
    },
    "spotlight": {
      "type": "object",
      "properties": {
        "active": { "type": "boolean" },
        "week": { "type": "integer", "minimum": 1 }
      },
      "required": ["active", "week"]
    },
    "fk_friday": {
      "type": "object",
      "properties": {
        "active": { "type": "boolean" },
        "week": { "type": "integer", "minimum": 1 }
      },
      "required": ["active", "week"]
    }
  },
  "required": [
    "id",
    "name",
    "school_website",
    "city",
    "state",
    "region",
    "votes_phase_1",
    "votes_phase_2",
    "rank",
    "description",
    "home_game",
    "spotlight",
    "fk_friday"
  ]
}
