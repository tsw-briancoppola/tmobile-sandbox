{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spotlight.schema.json",
  "title": "FN5GL Spotlight",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "integer" },
      "name": { "type": "string" },
      "region": { "type": "string", "enum": ["East", "West", "Central", "South"] },
      "week": { "type": "integer", "minimum": 1 }
    },
    "required": ["id", "name", "region", "week"]
  }
}
